# Copy to .env and fill in your values.

# Generate VAPID keys: go run github.com/SherClockHolmes/webpush-go/cmd/vapid-keygen@latest
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_EMAIL=mailto:dev@localhost

# Display name shown as the site heading — customise for your community.
# Examples: "Stop Nyons", "Covoiturage Drôme", "Go-Barjac"
SITE_NAME=Go-Stop

# Minutes after a ride's flex window closes before it disappears from listings (default: 60)
RIDE_GRACE_MINUTES=60
